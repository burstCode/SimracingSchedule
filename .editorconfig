dotnet_diagnostic.SA1518.severity = warning      # Code should not contain blank lines at end of file
dotnet_diagnostic.SA1519.severity = warning      # Braces should not be omitted from multi-line child statement
dotnet_diagnostic.SA1520.severity = warning      # Use braces consistently

# SA16xx: Naming rules
dotnet_diagnostic.SA1610.severity = warning      # Property documentation must have value text

# Отключаем конфликтующие с .editorconfig правила
dotnet_diagnostic.SA1117.severity = none         # Parameters should be on same line or separate lines
dotnet_diagnostic.SA1116.severity = none         # Split parameters should start on line after declaration
dotnet_diagnostic.SA1502.severity = none         # Element should not be on a single line
