# ============================================
# SimRacingSchedule - Code Analysis Configuration
# Единый источник для Roslyn, StyleCop и Sonar analyzers
# ============================================

root = true

# C# files
[*.cs]

#### Core EditorConfig Options ####

indent_size = 4
indent_style = space
tab_width = 4
end_of_line = crlf
insert_final_newline = false
charset = utf-8

#### .NET Coding Conventions ####

dotnet_separate_import_directive_groups = false
dotnet_sort_system_directives_first = false
file_header_template = unset

dotnet_style_qualification_for_event = false
dotnet_style_qualification_for_field = false
dotnet_style_qualification_for_method = false
dotnet_style_qualification_for_property = false

dotnet_style_predefined_type_for_locals_parameters_members = true
dotnet_style_predefined_type_for_member_access = true

dotnet_style_parentheses_in_arithmetic_binary_operators = always_for_clarity
dotnet_style_parentheses_in_other_binary_operators = always_for_clarity
dotnet_style_parentheses_in_relational_binary_operators = always_for_clarity

dotnet_style_require_accessibility_modifiers = for_non_interface_members

dotnet_style_coalesce_expression = true
dotnet_style_null_propagation = true
dotnet_style_object_initializer = true
dotnet_style_collection_initializer = true
dotnet_style_explicit_tuple_names = true
dotnet_style_prefer_auto_properties = true
dotnet_style_prefer_conditional_expression_over_assignment = true
dotnet_style_prefer_conditional_expression_over_return = true

dotnet_code_quality_unused_parameters = all

#### C# Coding Conventions ####

csharp_style_var_elsewhere = false
csharp_style_var_for_built_in_types = false
csharp_style_var_when_type_is_apparent = false

csharp_style_expression_bodied_accessors = when_on_single_line
csharp_style_expression_bodied_methods = when_on_single_line

csharp_style_pattern_matching_over_as_with_null_check = true
csharp_style_pattern_matching_over_is_with_cast_check = true
csharp_style_prefer_switch_expression = true

csharp_style_conditional_delegate_call = true

csharp_prefer_braces = true
csharp_prefer_simple_using_statement = true

csharp_using_directive_placement = outside_namespace

csharp_style_throw_expression = true

#### C# Formatting Rules ####

csharp_new_line_before_catch = true
csharp_new_line_before_else = true
csharp_new_line_before_finally = true
csharp_new_line_before_open_brace = all

csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents = true
csharp_indent_switch_labels = true

csharp_space_after_cast = false
csharp_space_after_comma = true
csharp_space_around_binary_operators = before_and_after

csharp_preserve_single_line_blocks = true

#### Naming Conventions ####

dotnet_naming_rule.interface_should_be_begins_with_i.severity = warning
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begins_with_i.style = begins_with_i

dotnet_naming_rule.types_should_be_pascal_case.severity = warning
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case

dotnet_naming_rule.private_or_internal_field_should_be_m_pascalcase.severity = none

# Allow underscore prefix for private fields (SA1309)
dotnet_diagnostic.SA1309.severity = none
dotnet_naming_rule.private_or_internal_field_should_be_m_pascalcase.symbols = private_or_internal_field
dotnet_naming_rule.private_or_internal_field_should_be_m_pascalcase.style = m_pascalcase

dotnet_naming_rule.parameter_should_be_camelcase.severity = silent
dotnet_naming_rule.parameter_should_be_camelcase.symbols = parameter
dotnet_naming_rule.parameter_should_be_camelcase.style = camelcase

dotnet_naming_rule.local_variable_should_be_camelcase.severity = silent
dotnet_naming_rule.local_variable_should_be_camelcase.symbols = local_variable
dotnet_naming_rule.local_variable_should_be_camelcase.style = camelcase

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.types.applicable_kinds = class, struct, interface, enum, delegate
dotnet_naming_symbols.private_or_internal_field.applicable_kinds = field
dotnet_naming_symbols.private_or_internal_field.applicable_accessibilities = internal, private, private_protected
dotnet_naming_symbols.parameter.applicable_kinds = parameter
dotnet_naming_symbols.local_variable.applicable_kinds = local

dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.capitalization = pascal_case

dotnet_naming_style.pascal_case.capitalization = pascal_case

dotnet_naming_style.m_pascalcase.required_prefix = m_
dotnet_naming_style.m_pascalcase.capitalization = pascal_case

dotnet_naming_style.camelcase.capitalization = camel_case

#### Platform Compatibility ####

dotnet_diagnostic.CA1416.severity = error

# ============================================
# CRITICAL RULES - Security & Bugs (Error level)
# ============================================

[*.cs]

# Security - Hardcoded secrets & passwords
dotnet_diagnostic.S2068.severity = error

# SQL Injection vulnerabilities
dotnet_diagnostic.S2077.severity = error
dotnet_diagnostic.S3649.severity = error

# Cross-Site Scripting (XSS)
dotnet_diagnostic.S4502.severity = error

# Null dereference / Null pointer
dotnet_diagnostic.S2259.severity = error
dotnet_diagnostic.CA1508.severity = error
dotnet_diagnostic.CA1806.severity = error

# Resource leaks & disposal
dotnet_diagnostic.S2222.severity = error        # Lock release
dotnet_diagnostic.S2930.severity = error        # IDisposable implementation
dotnet_diagnostic.S2931.severity = error        # IDisposable members
dotnet_diagnostic.S3881.severity = error        # IDisposable correctly
dotnet_diagnostic.S3966.severity = error        # Dispose twice
dotnet_diagnostic.S2302.severity = error        # Proper Dispose pattern

# Dead code & unused
dotnet_diagnostic.S1144.severity = error        # Unused private members
dotnet_diagnostic.S1172.severity = error        # Unused parameters
dotnet_diagnostic.S1481.severity = error        # Unused local variables
dotnet_diagnostic.S1854.severity = error        # Dead stores
dotnet_diagnostic.S1858.severity = error        # Use String.Contains

# Arithmetic overflow
dotnet_diagnostic.S2184.severity = error        # Math overflow
dotnet_diagnostic.S2330.severity = error        # Array covariance

# Infinite loops
dotnet_diagnostic.S1751.severity = error
dotnet_diagnostic.S2190.severity = error        # Recursion without exit
dotnet_diagnostic.S1994.severity = error        # Infinite for loop

# Exception handling
dotnet_diagnostic.S112.severity = error         # Catch Exception
dotnet_diagnostic.S3871.severity = error        # Exception types public
dotnet_diagnostic.S3872.severity = error        # Duplicate param names
dotnet_diagnostic.S3875.severity = error        # Overloads with different order

# Async/Await issues
dotnet_diagnostic.S2201.severity = error        # Ignored return values
dotnet_diagnostic.S3168.severity = error        # Async without await
dotnet_diagnostic.S4016.severity = error        # Async blocking
dotnet_diagnostic.S4018.severity = error        # Await usage
dotnet_diagnostic.S4019.severity = error        # Dispose call
dotnet_diagnostic.S4026.severity = error        # Task without await

# Serialization
dotnet_diagnostic.S3925.severity = error        # ISerializable
dotnet_diagnostic.S3926.severity = error        # ArgumentException
dotnet_diagnostic.S3928.severity = error        # Parameter name
dotnet_diagnostic.S3906.severity = error        # Event handlers return void
dotnet_diagnostic.S3903.severity = error        # Types in namespaces

# Static state issues
dotnet_diagnostic.S2223.severity = error        # Non-atomic operations on static
dotnet_diagnostic.S2386.severity = error        # Mutable static fields
dotnet_diagnostic.S3010.severity = error        # Static fields initialization
dotnet_diagnostic.S2696.severity = error        # Instance members from static

# Commented code
dotnet_diagnostic.S125.severity = error         # Commented code

# Cognitive complexity
dotnet_diagnostic.S3776.severity = warning      # Cognitive complexity (15 by default)

# TODO/FIXME warnings
dotnet_diagnostic.S1135.severity = suggestion   # TODO comments

# ============================================
# IMPORTANT RULES - Code Quality (Warning level)
# ============================================

# Dispose patterns
dotnet_diagnostic.S3963.severity = warning      # Static constructors
dotnet_diagnostic.S3971.severity = warning      # Dispose for IDisposable
dotnet_diagnostic.S3973.severity = warning      # Dispose pattern
dotnet_diagnostic.S4049.severity = warning      # Property with getter only

# Nullable reference types
dotnet_diagnostic.CA1062.severity = suggestion      # Validate arguments (public API)
dotnet_diagnostic.CA1303.severity = suggestion      # Do not pass literals as params
dotnet_diagnostic.CA2007.severity = none            # ConfigureAwait - for libraries, not needed

# Code quality
dotnet_diagnostic.S1659.severity = warning      # Multiple variables in one line
dotnet_diagnostic.S1643.severity = warning      # String concatenation in loop
dotnet_diagnostic.S2123.severity = warning      # Overwritten values
dotnet_diagnostic.S2325.severity = warning      # Methods can be static
dotnet_diagnostic.S2328.severity = warning      # GetHashCode override
dotnet_diagnostic.S3451.severity = warning      # Async method naming

# StyleCop - Keep only essential
dotnet_diagnostic.SA1201.severity = warning     # Elements order
dotnet_diagnostic.SA1202.severity = warning     # Access modifier order
dotnet_diagnostic.SA1204.severity = warning     # Static before instance
dotnet_diagnostic.SA1300.severity = warning     # Upper-case for elements
dotnet_diagnostic.SA1302.severity = warning     # Interface with I prefix
dotnet_diagnostic.SA1400.severity = warning     # Access modifier declared
dotnet_diagnostic.SA1401.severity = error       # Fields should be private
dotnet_diagnostic.SA1128.severity = warning     # Constructor on own line
dotnet_diagnostic.SA1503.severity = warning     # Braces required

# Suppress documentation rules (optional - set to warning if needed)
dotnet_diagnostic.SA1600.severity = none        # Elements must be documented
dotnet_diagnostic.SA1633.severity = none        # File header
dotnet_diagnostic.SA1200.severity = none        # Using placement

# Suppress verbose StyleCop rules
dotnet_diagnostic.SA0001.severity = none        # XML comment analysis disabled
dotnet_diagnostic.SA1005.severity = none        # Single line comment space
dotnet_diagnostic.SA1009.severity = none        # Closing parenthesis space
dotnet_diagnostic.SA1101.severity = none        # Prefix local calls with this
dotnet_diagnostic.SA1116.severity = none        # Parameters on separate lines
dotnet_diagnostic.SA1117.severity = none        # Parameters same line
dotnet_diagnostic.SA1308.severity = none        # m_ prefix (already handled by SA1309)
dotnet_diagnostic.SA1313.severity = none        # Parameter camelCase
dotnet_diagnostic.SA1413.severity = none        # Trailing comma
dotnet_diagnostic.SA1502.severity = none        # Single line elements
dotnet_diagnostic.SA1508.severity = none        # Blank line before brace
dotnet_diagnostic.SA1512.severity = none        # Blank line after comment
dotnet_diagnostic.SA1513.severity = none        # Blank line after brace
dotnet_diagnostic.SA1515.severity = none        # Blank line before comment
dotnet_diagnostic.SA1516.severity = none        # Elements separated by blank line

# ============================================
# TEST PROJECTS - Relaxed rules
# ============================================

[{**/*Tests.cs,**/*Test.cs}]
dotnet_diagnostic.S1135.severity = none
dotnet_diagnostic.S1481.severity = none
dotnet_diagnostic.S1854.severity = none
dotnet_diagnostic.S1172.severity = none
dotnet_diagnostic.S1186.severity = none
dotnet_diagnostic.S1603.severity = none
dotnet_diagnostic.S2699.severity = none        # Test should have assertions
dotnet_diagnostic.S101.severity = none          # Type name casing
