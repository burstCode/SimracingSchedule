dotnet_style_qualification_for_field = false:silent
dotnet_style_predefined_type_for_member_access = true:warning
end_of_line = crlf
dotnet_diagnostic.CA1416.severity = error

# ============================================
# SONAR ANALYZER RULES
# Дополнительные правила безопасности и качества кода
# ============================================

[*.cs]

# СБОР (Security) - критические правила безопасности
dotnet_diagnostic.S2068.severity = error        # Не хранить пароли/секреты в коде
dotnet_diagnostic.S2077.severity = error        # SQL injection уязвимости
dotnet_diagnostic.S2092.severity = error        # Cookie без Secure флага
dotnet_diagnostic.S2115.severity = error        # Безопасное использование GC.KeepAlive
dotnet_diagnostic.S2222.severity = error        # Правильное освобождение блокировок
dotnet_diagnostic.S2259.severity = error        # Null pointer dereference
dotnet_diagnostic.S2583.severity = error        # Недостижимый код из-за условий
dotnet_diagnostic.S2589.severity = error        # Булевы выражения всегда true/false
dotnet_diagnostic.S2696.severity = error        # Instance members access from static context
dotnet_diagnostic.S2755.severity = error        # XML уязвимости
dotnet_diagnostic.S4423.severity = error        # Слабые алгоритмы шифрования
dotnet_diagnostic.S4502.severity = error        # Cross-Site Scripting (XSS)
dotnet_diagnostic.S4507.severity = error        # Debug mode в production
dotnet_diagnostic.S4510.severity = error        # Deserialization vulnerabilities

# BAQ (Bugs and Quality) - критические баги
dotnet_diagnostic.S112.severity = error         # Не выбрасывать общие исключения
dotnet_diagnostic.S1135.severity = warning      # TODO/FIXME комменты
dotnet_diagnostic.S1144.severity = error        # Неиспользуемые private члены
dotnet_diagnostic.S1172.severity = error        # Неиспользуемые параметры методов
dotnet_diagnostic.S1186.severity = error        # Пустые методы
dotnet_diagnostic.S125.severity = error         # Закомментированный код
dotnet_diagnostic.S1450.severity = warning      # Поля, которые можно сделать локальными
dotnet_diagnostic.S1481.severity = error        # Неиспользуемые локальные переменные
dotnet_diagnostic.S1643.severity = error        # Конкатенация строк в цикле
dotnet_diagnostic.S1659.severity = error        # Объявление нескольких переменных в одной строке
dotnet_diagnostic.S1699.severity = warning      # Вызов виртуальных методов в конструкторе
dotnet_diagnostic.S1751.severity = warning      # Бесконечные циклы
dotnet_diagnostic.S1854.severity = error        # Бессмысленные присваивания
dotnet_diagnostic.S1858.severity = warning      # Использовать Contains вместо IndexOf
dotnet_diagnostic.S1862.severity = warning      # Инвертированные условия
dotnet_diagnostic.S1905.severity = warning      # Избыточные приведения типов
dotnet_diagnostic.S1939.severity = warning      # Избыточные интерфейсы
dotnet_diagnostic.S1940.severity = warning      # Инвертированные булевы выражения
dotnet_diagnostic.S1994.severity = warning      # Бесконечные циклы for
dotnet_diagnostic.S2114.severity = error        # Двойная перечисление IEnumerable
dotnet_diagnostic.S2123.severity = warning      # Перезаписанные значения
dotnet_diagnostic.S2139.severity = warning      # Логирование исключений
dotnet_diagnostic.S2184.severity = error        # Overflow в вычислениях
dotnet_diagnostic.S2190.severity = error        # Рекурсия без выхода
dotnet_diagnostic.S2197.severity = warning      # Modulus на float
dotnet_diagnostic.S2201.severity = error        # Игнорируемые возвращаемые значения
dotnet_diagnostic.S2219.severity = warning      # Избыточные проверки is/as
dotnet_diagnostic.S2223.severity = error        # Неатомарные операции над статикой
dotnet_diagnostic.S2225.severity = error        # ToString() возвращает null
dotnet_diagnostic.S2234.severity = warning      # Неправильный порядок параметров
dotnet_diagnostic.S2251.severity = warning      # Использовать foreach
